# Genesis pipeline environment.

# Comma-separated list of origins allowed to call the API. Override for
# production. Defaults cover local Vite dev (5173/4173).
GENESIS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging level for the FastAPI process.
GENESIS_LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Architect LLM
# -------------------------------------------------------------------------
# The architect agent uses any OpenAI-compatible endpoint. Default model is
# Qwen 2.5 72B Instruct (Apache 2.0, strongest open-weights model for
# structured-output / instruction-following tasks at the 70B scale).
#
# Recommended dev provider: OpenRouter
#   GENESIS_LLM_BASE_URL=https://openrouter.ai/api/v1
#   GENESIS_LLM_API_KEY=sk-or-v1-...
#   GENESIS_ARCHITECT_MODEL=qwen/qwen-2.5-72b-instruct
#
# Other open-weights options:
#   meta-llama/llama-3.3-70b-instruct
#   deepseek/deepseek-chat                # DeepSeek V3, top reasoning
#   qwen/qwen-2.5-32b-instruct            # smaller, faster
#
# Self-hosted on your A100 (vLLM):
#   GENESIS_LLM_BASE_URL=http://127.0.0.1:8000/v1
#   GENESIS_LLM_API_KEY=local-no-key
#   GENESIS_ARCHITECT_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
#
# Local Ollama:
#   GENESIS_LLM_BASE_URL=http://127.0.0.1:11434/v1
#   GENESIS_ARCHITECT_MODEL=qwen2.5:72b-instruct
#
# Leave all of these unset to use the deterministic rule-based fallback.
GENESIS_LLM_BASE_URL=
GENESIS_LLM_API_KEY=
GENESIS_ARCHITECT_MODEL=qwen/qwen-2.5-72b-instruct

# Optional tuning.
GENESIS_LLM_TEMPERATURE=0.4
GENESIS_LLM_MAX_TOKENS=2000
GENESIS_LLM_TIMEOUT=45
GENESIS_LLM_RETRIES=2

# -------------------------------------------------------------------------
# Blender shell builder
# -------------------------------------------------------------------------
# /build_shell uses Blender 3.6+ in headless mode to extrude the FloorPlan
# into a real 3D shell with boolean-cut openings and export a .glb.
#
# Resolution order:
#   1. GENESIS_BLENDER_BIN (explicit override)
#   2. `blender` on PATH
#   3. /Applications/Blender.app/Contents/MacOS/Blender (macOS default)
#
# Install:
#   macOS:   brew install --cask blender
#   Ubuntu:  sudo apt install blender   (or download official tarball for 4.x)
#   Windows: download installer from blender.org
#
# Leave unset and Genesis will use whatever's on PATH; if nothing is found,
# /build_shell returns a clear 503 and the editor shows a helpful banner.
GENESIS_BLENDER_BIN=

# -------------------------------------------------------------------------
# Vision Language Model (VLM)
# -------------------------------------------------------------------------
# The VLM analyzes reference images during intake (style detection, material
# identification, mood analysis) and can critique generated floor plans.
#
# Backend: "fastvlm" (Apple Silicon, on-device) or "openai" (cloud API)
#
# Apple FastVLM (recommended for Mac — zero-latency, private):
#   GENESIS_VLM_BACKEND=fastvlm
#   GENESIS_VLM_MODEL=FastVLM-0.5B         # 0.5B (fast), 1.5B, 7B (best)
#   pip install mlx mlx-vlm
#
# OpenAI-compatible vision API (GPT-4o, LLaVA, Qwen-VL):
#   GENESIS_VLM_BACKEND=openai
#   GENESIS_VLM_BASE_URL=                   # leave empty for OpenAI
#   GENESIS_VLM_API_KEY=sk-...
#   GENESIS_VLM_MODEL=gpt-4o
#
# Leave all unset to disable VLM features (intake works without it).
GENESIS_VLM_BACKEND=
GENESIS_VLM_MODEL=
GENESIS_VLM_BASE_URL=
GENESIS_VLM_API_KEY=

# Reserved for upcoming integrations.
# HUNYUAN3D_ENDPOINT=
# TRELLIS_ENDPOINT=
